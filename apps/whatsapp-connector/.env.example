# Port du serveur
PORT=3001

# CORS origin (pour le frontend si nécessaire)
CORS_ORIGIN=http://localhost:5173

# Chemin de stockage des sessions WhatsApp
WHATSAPP_SESSION_PATH=./data/sessions

# URLs des webhooks (séparées par des virgules)
# Ces URLs recevront tous les événements WhatsApp (message, qr, ready, etc.)
WEBHOOK_URLS=http://localhost:3002/webhook/message,http://localhost:3000/webhook/whatsapp
