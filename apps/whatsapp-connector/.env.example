# Server
PORT=3001
NODE_ENV=development

# WhatsApp Session
WHATSAPP_SESSION_PATH=./data/sessions
WHATSAPP_PUPPETEER_HEADLESS=false
PUPPETEER_EXECUTABLE_PATH=

# Backend Webhook
BACKEND_WEBHOOK_URL=http://localhost:3000
BACKEND_INTERNAL_URL=https://127.0.0.1:9443

# Webhook URLs (comma-separated)
# Use this URL for all WhatsApp events (qr, authenticated, message, etc.)
WEBHOOK_URLS=https://127.0.0.1:9443/webhooks/whatsapp/events,https://127.0.0.1:9443/webhooks/whatsapp/connected

# Connector Security
CONNECTOR_SECRET=your-connector-signature-secret
CONNECTOR_INSTANCE_ID=bedones-wa-slot-1
WHATSAPP_AUTOSTART=false
MTLS_CLIENT_CERT=
MTLS_CLIENT_KEY=
STEP_CA_ROOT_CERT=

# Minio Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=whatsapp-user
MINIO_SECRET_KEY=your-secret-key-here
MINIO_BUCKET=whatsapp-agent
