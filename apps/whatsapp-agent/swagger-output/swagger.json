                      "type": "string"
                    },
                    "width": {
                      "type": "number"
                    },
                    "height": {
                      "type": "number"
                    },
                    "coordinates": {
                      "type": "object"
                    },
                    "confidence": {
                      "type": "number"
                    },
                    "croppedPath": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "image-processing-test"
        ]
      }
