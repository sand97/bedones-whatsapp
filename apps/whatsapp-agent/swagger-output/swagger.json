    "/catalog/sync": {
      "post": {
        "operationId": "CatalogController_triggerSync",
        "summary": "Trigger manual catalog synchronization",
        "description": "Forces immediate catalog sync with WhatsApp connector, including embeddings generation",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Sync triggered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Catalog"
        ]
      }
    },
    "/catalog/status": {
      "get": {
        "operationId": "CatalogController_getSyncStatus",
        "summary": "Get catalog sync status",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Sync status retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "isSyncing": {
                      "type": "boolean"
                    },
                    "lastSyncTime": {
                      "type": "string",
                      "nullable": true
                    },
                    "embeddingsAvailable": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Catalog"
        ]
      }
    },
    "/webhook/message": {
