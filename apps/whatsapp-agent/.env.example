# Port du serveur
PORT=3002

# CORS origin
CORS_ORIGIN=http://localhost:5173

# WhatsApp Connector URL
CONNECTOR_URL=http://localhost:3001

# Grok API (xAI) - Primary model
GROK_API_KEY=
GROK_API_BASE=https://api.x.ai/v1
GROK_MODEL=grok-beta

# Gemini API (Google) - Fallback model
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# Agent configuration
AGENT_SYSTEM_PROMPT=You are a helpful WhatsApp assistant. You can read and send messages, get chat information, and help users with their WhatsApp conversations. Always be polite and helpful.
